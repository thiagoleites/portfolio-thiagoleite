# Environment Configuration
NODE_ENV="development"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ==========================================
# AI API Keys & Configuration
# ==========================================

# Gemini API: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI API: For GPT models and other OpenAI services
OPENAI_API_KEY="MY_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4-turbo"
OPENAI_ORGANIZATION_ID=""

# Anthropic Claude API: For Claude model family
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"
ANTHROPIC_MODEL="claude-3-sonnet-20240229"

# Azure OpenAI: If using Azure-hosted OpenAI services
AZURE_OPENAI_API_KEY="MY_AZURE_OPENAI_API_KEY"
AZURE_OPENAI_ENDPOINT="https://<your-resource-name>.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4-turbo"

# Generic AI Configuration
AI_MODEL_DEFAULT="gemini"
AI_REQUEST_TIMEOUT=30000

# ==========================================
# n8n Workflow Integration
# ==========================================

# n8n Webhook URL: For triggering n8n workflows
N8N_WEBHOOK_URL="https://n8n.thiagoleite.eu/webhook/my-workflow"

# n8n API Configuration: For programmatic workflow management
N8N_API_URL="https://n8n.thiagoleite.eu/api"
N8N_API_KEY="MY_N8N_API_KEY"

# n8n Webhook Secret: Optional security token for webhook validation
N8N_WEBHOOK_SECRET="MY_N8N_WEBHOOK_SECRET"

# ==========================================
# Feature Flags & Options
# ==========================================

# Enable AI features
ENABLE_AI_FEATURES="true"

# Enable n8n integrations
ENABLE_N8N_INTEGRATION="false"

# Enable contact form submissions via n8n
ENABLE_N8N_CONTACT_FORM="false"

# ==========================================
# Optional: Other AI Services
# ==========================================

# Hugging Face API: For ML models and inference
HUGGINGFACE_API_KEY="MY_HUGGINGFACE_API_KEY"

# Cohere API: For NLP tasks
COHERE_API_KEY="MY_COHERE_API_KEY"

# Replicate API: For running ML models
REPLICATE_API_TOKEN="MY_REPLICATE_API_TOKEN"
